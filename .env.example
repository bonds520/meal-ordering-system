# LINE 官方帳號設定
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# 資料庫設定
DATABASE_URL=postgresql://mealorder:mealorder_password@db:5432/mealorder

# 伺服器設定
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# 認證設定
SECRET_KEY=your_secret_key_here_change_this

# 管理員設定 (LINE User ID)
ADMIN_USER_IDS=admin_user_id_1,admin_user_id_2

# 訂餐設定
DEFAULT_SUBSIDY=150
ORDER_DEADLINE_HOUR=11
ORDER_DEADLINE_MINUTE=30
PICKUP_START_HOUR=11
PICKUP_START_MINUTE=30
PICKUP_END_HOUR=13
PICKUP_END_MINUTE=0

# 每日補助重置時間 (24 小時制)
DAILY_SUBSIDY_RESET_HOUR=0

# 上傳設定
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10

# Celery 設定 (排程任務)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# 日誌設定
LOG_LEVEL=INFO
